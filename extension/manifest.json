{
  "manifest_version": 3,
  "name": "BamSEC Transcript Summarizer",
  "version": "1.0.0",
  "description": "Extract earnings call transcripts from BamSEC and summarize via Claude",
  "permissions": ["activeTab", "scripting", "tabs", "alarms", "storage", "contextMenus"],
  "host_permissions": [
    "https://www.bamsec.com/*",
    "http://localhost:3210/*",
    "https://*.tegus.co/*",
    "https://*.alphasense.com/*",
    "https://*.alpha-sense.com/*",
    "https://*.alphasights.com/*"
  ],
  "action": {
    "default_title": "Summarize Transcript",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
